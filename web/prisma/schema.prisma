// Teedeux — Dual-fulfillment grocery platform schema
// Local On-Demand Delivery + Nationwide Shipping

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum UserRole {
  CUSTOMER
  SHOPPER
  VENDOR
  ADMIN
}

enum FulfillmentType {
  LOCAL_ONLY
  SHIPPING_ONLY
  BOTH
}

enum RegionCategory {
  WEST_AFRICAN
  EAST_AFRICAN
  CENTRAL_AFRICAN
  NORTH_AFRICAN
  SOUTHERN_AFRICAN
  CARIBBEAN
  GENERAL
}

enum TemperatureClass {
  FRESH
  FROZEN
  DRY
}

enum ProductUnit {
  EACH
  LB
  OZ
  KG
  G
  BUNCH
  PACK
}

enum OrderType {
  LOCAL_DELIVERY
  NATIONWIDE_SHIPPING
}

enum OrderStatus {
  PENDING
  CONFIRMED
  SHOPPING
  READY_FOR_DELIVERY
  OUT_FOR_DELIVERY
  LABEL_CREATED
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum OrderItemStatus {
  PENDING
  FOUND
  SUBSTITUTION_PENDING
  SUBSTITUTED
  REFUNDED
  UNAVAILABLE
}

enum DeliveryStatus {
  UNASSIGNED
  ASSIGNED
  EN_ROUTE_TO_STORE
  SHOPPING
  EN_ROUTE_TO_CUSTOMER
  DELIVERED
  CANCELLED
}

enum StoreStatus {
  ACTIVE
  INACTIVE
  PENDING_REVIEW
}

// ─── Models ──────────────────────────────────────────────────────────────────

model User {
  id               String   @id @default(cuid())
  email            String   @unique
  phone            String?
  name             String
  role             UserRole @default(CUSTOMER)
  avatarUrl        String?
  stripeCustomerId String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  addresses     Address[]
  orders        Order[]               @relation("CustomerOrders")
  deliveries    Delivery[]            @relation("ShopperDeliveries")
  vendorStores  Store[]               @relation("VendorStores")
  substitutions SubstitutionRequest[] @relation("CustomerSubstitutions")

  @@index([role])
  @@index([email])
}

model Address {
  id         String   @id @default(cuid())
  userId     String?
  storeId    String?  @unique
  label      String?
  line1      String
  line2      String?
  city       String
  state      String
  postalCode String
  country    String   @default("US")
  latitude   Float?
  longitude  Float?
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)
  store  Store?  @relation(fields: [storeId], references: [id], onDelete: Cascade)
  orders Order[]

  @@index([userId])
  @@index([postalCode])
}

model Store {
  id               String           @id @default(cuid())
  vendorId         String
  name             String
  slug             String           @unique
  description      String?
  logoUrl          String?
  coverImageUrl    String?
  phone            String?
  email            String?
  fulfillmentType  FulfillmentType  @default(BOTH)
  status           StoreStatus      @default(PENDING_REVIEW)
  localRadiusMiles Float            @default(15)
  stripeAccountId  String?
  operatingHours   Json?
  regionFocus      RegionCategory[]
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  vendor   User      @relation("VendorStores", fields: [vendorId], references: [id])
  address  Address?
  products Product[]
  orders   Order[]

  @@index([vendorId])
  @@index([fulfillmentType])
  @@index([status])
}

model Product {
  id               String           @id @default(cuid())
  storeId          String
  name             String
  slug             String
  description      String?
  imageUrl         String?
  sku              String?
  region           RegionCategory   @default(GENERAL)
  temperatureClass TemperatureClass @default(DRY)
  unit             ProductUnit      @default(EACH)
  priceCents       Int
  weightOz         Float?
  stockQty         Int              @default(0)
  isWeighted       Boolean          @default(false)
  shippable        Boolean          @default(true)
  localAvailable   Boolean          @default(true)
  isActive         Boolean          @default(true)
  tags             String[]
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  store      Store       @relation(fields: [storeId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]

  @@unique([storeId, slug])
  @@index([storeId])
  @@index([region])
  @@index([temperatureClass])
  @@index([shippable, localAvailable])
}

model Order {
  id                String      @id @default(cuid())
  orderNumber       String      @unique
  customerId        String
  storeId           String
  orderType         OrderType
  status            OrderStatus @default(PENDING)
  deliveryAddressId String?

  subtotalCents    Int
  deliveryFeeCents Int          @default(0)
  shippingFeeCents Int          @default(0)
  serviceFeeCents  Int          @default(0)
  tipCents         Int          @default(0)
  taxCents         Int          @default(0)
  totalCents       Int

  shippingCarrier     String?
  shippingService     String?
  trackingNumber      String?
  shippingLabelUrl    String?
  estimatedDeliveryAt DateTime?

  stripePaymentIntentId String?
  notes                 String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  customer        User                  @relation("CustomerOrders", fields: [customerId], references: [id])
  store           Store                 @relation(fields: [storeId], references: [id])
  deliveryAddress Address?              @relation(fields: [deliveryAddressId], references: [id])
  items           OrderItem[]
  delivery        Delivery?
  substitutions   SubstitutionRequest[]

  @@index([customerId])
  @@index([storeId])
  @@index([orderType, status])
  @@index([createdAt])
}

model OrderItem {
  id               String          @id @default(cuid())
  orderId          String
  productId        String
  quantity         Float
  unitPriceCents   Int
  status           OrderItemStatus @default(PENDING)
  substitutionNote String?
  refundedCents    Int             @default(0)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  order         Order                 @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product       Product               @relation(fields: [productId], references: [id])
  substitutions SubstitutionRequest[]

  @@index([orderId])
  @@index([productId])
}

model Delivery {
  id            String         @id @default(cuid())
  orderId       String         @unique
  shopperId     String?
  status        DeliveryStatus @default(UNASSIGNED)
  payoutCents   Int            @default(0)
  currentLat    Float?
  currentLng    Float?
  assignedAt    DateTime?
  pickedUpAt    DateTime?
  deliveredAt   DateTime?
  externalJobId String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  order   Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  shopper User? @relation("ShopperDeliveries", fields: [shopperId], references: [id])

  @@index([shopperId])
  @@index([status])
}

model SubstitutionRequest {
  id                  String   @id @default(cuid())
  orderId             String
  orderItemId         String
  customerId          String
  suggestedName       String
  suggestedPriceCents Int?
  note                String?
  approved            Boolean?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  order     Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderItem OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  customer  User      @relation("CustomerSubstitutions", fields: [customerId], references: [id])

  @@index([orderId])
  @@index([orderItemId])
}

model RecipeBundle {
  id          String         @id @default(cuid())
  name        String
  slug        String         @unique
  region      RegionCategory
  description String?
  imageUrl    String?
  ingredients Json
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([region])
}
