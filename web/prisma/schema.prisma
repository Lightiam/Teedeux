// Teedeux — RBAC + dual-fulfillment grocery platform
// Inspired by AfroConnect marketplace UX; Super Admin: teedeux.dev@gmail.com

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  VENDOR
  SHOPPER
  CUSTOMER
}

enum FulfillmentType {
  LOCAL_ONLY
  SHIPPING_ONLY
  HYBRID
}

enum OrderType {
  LOCAL_DELIVERY
  NATIONWIDE_SHIPPING
}

enum OrderStatus {
  PENDING
  PROCESSING
  PICKING
  SHIPPED
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  phone        String?
  passwordHash String
  role         Role     @default(CUSTOMER)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  stores            Store[]     @relation("VendorStores")
  customerOrders    Order[]     @relation("CustomerOrders")
  shopperDeliveries Order[]     @relation("ShopperDeliveries")
  auditLogs         AuditLog[]

  @@index([role])
  @@index([isActive])
}

model Store {
  id              String          @id @default(cuid())
  name            String
  slug            String          @unique
  ownerId         String
  owner           User            @relation("VendorStores", fields: [ownerId], references: [id])
  fulfillmentType FulfillmentType @default(HYBRID)
  address         String
  city            String
  state           String
  zipCode         String
  isVerified      Boolean         @default(false)
  coverImageUrl   String?
  description     String?
  products        Product[]
  orders          Order[]
  createdAt       DateTime        @default(now())

  @@index([ownerId])
  @@index([city, state])
}

model Product {
  id            String   @id @default(cuid())
  storeId       String
  store         Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  title         String
  description   String?
  price         Decimal  @db.Decimal(10, 2)
  category      String
  originRegion  String?
  weightOz      Float?
  requiresCold  Boolean  @default(false)
  stockQuantity Int      @default(0)
  imageUrl      String?
  createdAt     DateTime @default(now())

  @@index([storeId])
  @@index([category])
}

model Order {
  id              String      @id @default(cuid())
  orderNumber     String      @unique @default(cuid())
  customerId      String
  customer        User        @relation("CustomerOrders", fields: [customerId], references: [id])
  storeId         String
  store           Store       @relation(fields: [storeId], references: [id])
  shopperId       String?
  shopper         User?       @relation("ShopperDeliveries", fields: [shopperId], references: [id])

  orderType       OrderType
  status          OrderStatus @default(PENDING)

  subtotal        Decimal     @db.Decimal(10, 2)
  deliveryFee     Decimal     @db.Decimal(10, 2)
  shippingFee     Decimal     @db.Decimal(10, 2)
  totalAmount     Decimal     @db.Decimal(10, 2)

  trackingNumber  String?
  shippingCarrier String?

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([customerId])
  @@index([storeId])
  @@index([shopperId])
  @@index([orderType, status])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  action    String
  targetId  String?
  details   String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}
