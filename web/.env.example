# Leave DATABASE_URL unset (or keep the placeholder) to use in-memory RBAC demo.
# Set a real Postgres URL + TEEDEUX_USE_MEMORY=0 to use Prisma.
# DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/teedeux?schema=public"

# Force memory mode even if DATABASE_URL is set
TEEDEUX_USE_MEMORY=1

# Auth JWT cookie secret (required in production)
AUTH_SECRET="replace-with-a-long-random-string"

# Stripe Connect (Phase 1+)
# STRIPE_SECRET_KEY=
# STRIPE_PUBLISHABLE_KEY=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Shipping (Phase 2) — Shippo or EasyPost
# SHIPPO_API_KEY=
# EASYPOST_API_KEY=
